# This file isn't exhaustive of every env var this project reads (see
# api/lead.js, api/m/[slug].js, vite.config.ts for others: POSTGRES_URL,
# GEMINI_API_KEY, LEAD_INGEST_SECRET, LEAD_NTFY_TOPIC, NEXT_PUBLIC_GTAG_ID,
# NEXT_PUBLIC_GADS_CONVERSION). It documents the two added for the content
# CMS pipeline (scripts/fetch-content.mjs).

# Build-time only (set in Vercel project settings, never VITE_-prefixed —
# these must never reach the client bundle). Both required for
# scripts/fetch-content.mjs to pull published content from walt-crm; if
# either is unset the build logs a warning and keeps whatever content/
# already has on disk (never fails the build).
#
# CRM_CONTENT_API_URL: the walt-crm deployment's origin, e.g.
#   https://walt-crm.vercel.app
# CONTENT_EXPORT_SECRET: same value as CONTENT_EXPORT_SECRET on the walt-crm
#   project — authenticates GET /api/content/export?key=...
CRM_CONTENT_API_URL=
CONTENT_EXPORT_SECRET=
