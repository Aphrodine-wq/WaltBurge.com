{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/m/:slug", "destination": "/api/m/:slug" },
    { "source": "/websites", "destination": "https://walt-crm.vercel.app/websites" },
    { "source": "/websites/:path*", "destination": "https://walt-crm.vercel.app/websites/:path*" },
    { "source": "/portfolio/:path*", "destination": "https://walt-crm.vercel.app/portfolio/:path*" },
    { "source": "/_next/:path*", "destination": "https://walt-crm.vercel.app/_next/:path*" }
  ]
}
