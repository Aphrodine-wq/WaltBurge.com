{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/audit.js": { "maxDuration": 60 }
  },
  "redirects": [
    { "source": "/blog/:slug*", "destination": "https://waltbuilds.com/notes/:slug*", "permanent": true },
    { "source": "/", "destination": "https://waltbuilds.com/", "permanent": true },
    { "source": "/contact", "destination": "https://waltbuilds.com/contact", "permanent": true }
  ],
  "rewrites": [
    { "source": "/m/:slug", "destination": "/api/m/:slug" },
    { "source": "/websites", "destination": "https://walt-crm.vercel.app/websites" },
    { "source": "/websites/:path*", "destination": "https://walt-crm.vercel.app/websites/:path*" },
    { "source": "/portfolio/:path*", "destination": "https://walt-crm.vercel.app/portfolio/:path*" },
    { "source": "/_next/:path*", "destination": "https://walt-crm.vercel.app/_next/:path*" }
  ]
}
