# Content is now generated by scripts/fetch-content.mjs from walt-crm's CMS
# (/content) at prebuild time — these are build artifacts, not hand-edited
# source. Editing them directly has no lasting effect; the next build
# overwrites them from the CRM. Edit content in the CRM's /content page instead.
content/blog/*.md
content/services/*.md
content/work/items.json
content/local/pages.json
